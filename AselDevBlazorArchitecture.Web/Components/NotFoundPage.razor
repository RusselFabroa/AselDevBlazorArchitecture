@page "/{*route:nonfile}"



<MudStack AlignItems="AlignItems.Center">
	<MudImage Src="/no-content.png" Width="200" Class="mb-4" />
	<MudText Typo="Typo.h4" Color="Color.Error">404 - Not Found</MudText>
