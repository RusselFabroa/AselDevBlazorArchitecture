@page "/"
@layout Layout.MainLayout

<PageTitle>AselDev Blazor Architecture</PageTitle>

<div class="architecture-home">
    <section class="hero" aria-labelledby="home-title">
        <div class="hero-copy">
            <div class="eyebrow"><span></span> AselDev architecture foundation</div>
            <h1 id="home-title">Build enterprise Blazor applications from a clean, adaptable core.</h1>
            <p class="hero-lead">
                A reusable .NET 8 foundation with enforced application boundaries, optional persistence,
                secure browser sessions, API authentication, and independent PostgreSQL and MySQL migrations.
            </p>

            <div class="hero-actions">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Href="#architecture"
                           EndIcon="@Icons.Material.Outlined.ArrowDownward">
                    Explore architecture
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Href="#capabilities"
                           EndIcon="@Icons.Material.Outlined.ArrowForward">
                    View capabilities
                </MudButton>
            </div>

            <div class="technology-row" aria-label="Core technology stack">
                <span>.NET 8 LTS</span>
                <span>Blazor Server</span>
                <span>Clean Architecture</span>
                <span>Database Optional</span>
            </div>
        </div>

        <div class="hero-diagram" aria-label="Architecture dependency overview">
            <div class="diagram-heading">
                <span>Dependency direction</span>
                <span class="diagram-status"><i></i> Build verified</span>
            </div>

            <div class="diagram-main">
                <div class="diagram-node web-node">
                    <MudIcon Icon="@Icons.Material.Outlined.Web" />
                    <div><strong>Web</strong><span>UI · API · Composition</span></div>
                </div>
                <div class="flow-arrow">↓</div>
                <div class="diagram-node application-node">
                    <MudIcon Icon="@Icons.Material.Outlined.AccountTree" />
                    <div><strong>Application</strong><span>Use cases · Contracts</span></div>
                </div>
                <div class="flow-arrow">↓</div>
                <div class="diagram-node domain-node">
                    <MudIcon Icon="@Icons.Material.Outlined.Hub" />
                    <div><strong>Domain</strong><span>Business model · Rules</span></div>
                </div>
            </div>

            <div class="infra-rail">
                <div class="rail-line"></div>
                <div class="diagram-node infrastructure-node">
                    <MudIcon Icon="@Icons.Material.Outlined.SettingsInputComponent" />
                    <div><strong>Infrastructure</strong><span>Implements capabilities</span></div>
                </div>
                <div class="adapter-row">
                    <span>PostgreSQL</span>
                    <span>MySQL</span>
                    <span>Identity</span>
                    <span>JWT</span>
                </div>
            </div>
        </div>
    </section>

    <section id="capabilities" class="section capability-section">
        <div class="section-intro">
            <div>
                <span class="section-kicker">Core capabilities</span>
                <h2>Useful infrastructure without premature commitment.</h2>
            </div>
            <p>
                Start with a buildable application and introduce database, identity, and integration
                capabilities only when the product requires them.
            </p>
        </div>

        <div class="capability-grid">
            <article class="capability-card featured">
                <div class="card-number">01</div>
                <MudIcon Icon="@Icons.Material.Outlined.AccountTree" />
                <h3>Clean boundaries</h3>
                <p>UI components depend on application contracts—not EF Core, Identity, or provider implementations.</p>
                <span class="card-detail">Web → Application → Domain</span>
            </article>
            <article class="capability-card">
                <div class="card-number">02</div>
                <MudIcon Icon="@Icons.Material.Outlined.ToggleOff" />
                <h3>Optional persistence</h3>
                <p>Clone, restore, build, and run with no database. Persistence is an explicit capability switch.</p>
                <span class="card-detail">No startup connection</span>
            </article>
            <article class="capability-card">
                <div class="card-number">03</div>
                <MudIcon Icon="@Icons.Material.Outlined.Storage" />
                <h3>Database flexibility</h3>
                <p>PostgreSQL and MySQL use independent migration histories with provider-correct generated SQL.</p>
                <span class="card-detail">PostgreSQL recommended</span>
            </article>
            <article class="capability-card">
                <div class="card-number">04</div>
                <MudIcon Icon="@Icons.Material.Outlined.Security" />
                <h3>Secure authentication</h3>
                <p>HttpOnly Identity cookies protect browser sessions while JWT bearer tokens serve APIs and SSO.</p>
                <span class="card-detail">Cookies + JWT</span>
            </article>
            <article class="capability-card">
                <div class="card-number">05</div>
                <MudIcon Icon="@Icons.Material.Outlined.VpnKey" />
                <h3>SSO foundation</h3>
                <p>Identity Provider and client modes support a central portal with connected module applications.</p>
                <span class="card-detail">One capability, not a dependency</span>
            </article>
            <article class="capability-card">
                <div class="card-number">06</div>
                <MudIcon Icon="@Icons.Material.Outlined.Verified" />
                <h3>Operational safety</h3>
                <p>Secrets stay outside source control and migrations remain explicit, reviewable deployment steps.</p>
                <span class="card-detail">No automatic schema mutation</span>
            </article>
        </div>
    </section>

    <section id="architecture" class="section architecture-section">
        <div class="section-intro compact">
            <div>
                <span class="section-kicker">Solution map</span>
                <h2>Every project has one clear responsibility.</h2>
            </div>
        </div>

        <div class="layer-list">
            <article class="layer-row web">
                <div class="layer-index">01</div>
                <div class="layer-icon"><MudIcon Icon="@Icons.Material.Outlined.Web" /></div>
                <div class="layer-copy">
                    <div class="layer-heading"><h3>Web</h3><code>AselDevBlazorArchitecture.Web</code></div>
                    <p>Hosts the Blazor UI, HTTP endpoints, middleware pipeline, configuration, and dependency composition.</p>
                </div>
                <span class="layer-rule">Presentation</span>
            </article>

            <article class="layer-row application">
                <div class="layer-index">02</div>
                <div class="layer-icon"><MudIcon Icon="@Icons.Material.Outlined.AccountTree" /></div>
                <div class="layer-copy">
                    <div class="layer-heading"><h3>Application</h3><code>AselDevBlazorArchitecture.Application</code></div>
                    <p>Defines use cases, service contracts, request models, DTOs, and workflows independent of infrastructure.</p>
                </div>
                <span class="layer-rule">Orchestration</span>
            </article>

            <article class="layer-row domain">
                <div class="layer-index">03</div>
                <div class="layer-icon"><MudIcon Icon="@Icons.Material.Outlined.Hub" /></div>
                <div class="layer-copy">
                    <div class="layer-heading"><h3>Domain</h3><code>AselDevBlazorArchitecture.Domain</code></div>
                    <p>Contains the core business model and rules, with no dependency on UI, databases, or frameworks.</p>
                </div>
                <span class="layer-rule">Business core</span>
            </article>

            <article class="layer-row infrastructure">
                <div class="layer-index">04</div>
                <div class="layer-icon"><MudIcon Icon="@Icons.Material.Outlined.SettingsInputComponent" /></div>
                <div class="layer-copy">
                    <div class="layer-heading"><h3>Infrastructure</h3><code>AselDevBlazorArchitecture.Infrastructure</code></div>
                    <p>Implements persistence, Identity, authentication, logging, and external integrations behind application contracts.</p>
                </div>
                <span class="layer-rule">Adapters</span>
            </article>

            <article class="layer-row migrations">
                <div class="layer-index">05</div>
                <div class="layer-icon"><MudIcon Icon="@Icons.Material.Outlined.Schema" /></div>
                <div class="layer-copy">
                    <div class="layer-heading"><h3>Migration adapters</h3><code>PostgreSql · MySql</code></div>
                    <p>Maintain isolated provider-specific schema histories and design-time factories without business logic.</p>
                </div>
                <span class="layer-rule">Schema delivery</span>
            </article>
        </div>
    </section>

    <section class="section growth-section">
        <div class="growth-copy">
            <span class="section-kicker">Deliberate growth</span>
            <h2>Begin with the architecture. Add infrastructure when the product demands it.</h2>
            <p>A predictable path from an empty foundation to a secure, connected enterprise application.</p>
        </div>

        <ol class="growth-steps">
            <li><span>01</span><div><strong>Run without a database</strong><small>Validate the product and UI first.</small></div></li>
            <li><span>02</span><div><strong>Enable persistence</strong><small>Select PostgreSQL or MySQL explicitly.</small></div></li>
            <li><span>03</span><div><strong>Provision identity</strong><small>Add users and roles through approved workflows.</small></div></li>
            <li><span>04</span><div><strong>Connect applications</strong><small>Introduce API access and SSO when needed.</small></div></li>
        </ol>
    </section>

    <section class="section authentication-section">
        <div class="auth-heading">
            <span class="section-kicker">Authentication model</span>
            <h2>One identity foundation. Clear security responsibilities.</h2>
        </div>
        <div class="auth-grid">
            <article>
                <MudIcon Icon="@Icons.Material.Outlined.DesktopWindows" />
                <div><h3>Browser sessions</h3><p>HttpOnly Identity cookies inaccessible to JavaScript.</p></div>
            </article>
            <article>
                <MudIcon Icon="@Icons.Material.Outlined.Api" />
                <div><h3>API access</h3><p>Validated JWT bearer tokens for service endpoints.</p></div>
            </article>
            <article>
                <MudIcon Icon="@Icons.Material.Outlined.DeviceHub" />
                <div><h3>Cross-application SSO</h3><p>Identity Provider and client modes for module apps.</p></div>
            </article>
        </div>
    </section>

    <section class="closing-section">
        <div>
            <span class="section-kicker">Ready by design</span>
            <h2>A foundation teams can understand, extend, and operate safely.</h2>
        </div>
        <div class="closing-actions">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/login" StartIcon="@Icons.Material.Outlined.Login">
                Sign in
            </MudButton>
            <MudButton Variant="Variant.Outlined" Href="/company-dx-portal" StartIcon="@Icons.Material.Outlined.Dashboard">
                View portal example
            </MudButton>
        </div>
    </section>
</div>

<style>
    .architecture-home {
        --ink: #10213d;
        --ink-soft: #43536c;
        --blue: #2563eb;
        --blue-deep: #153b87;
        --blue-soft: #edf4ff;
        --teal: #087f75;
        --line: #dbe4f0;
        --surface-soft: #f5f8fc;
        color: var(--ink);
        margin: -24px;
        overflow: hidden;
    }

    .hero {
        background:
            radial-gradient(circle at 82% 12%, rgba(59, 130, 246, .14), transparent 28%),
            linear-gradient(140deg, #f9fbff 0%, #ffffff 58%, #f1f6ff 100%);
        border-bottom: 1px solid var(--line);
        display: grid;
        gap: clamp(34px, 5vw, 72px);
        grid-template-columns: minmax(0, 1.08fr) minmax(380px, .92fr);
        min-height: 620px;
        padding: clamp(58px, 8vw, 104px) max(28px, calc((100vw - 1340px) / 2));
    }

    .hero-copy {
        align-self: center;
        max-width: 760px;
    }

    .eyebrow,
    .section-kicker {
        color: var(--blue);
        font-size: .72rem;
        font-weight: 800;
        letter-spacing: .12em;
        text-transform: uppercase;
    }

    .eyebrow {
        align-items: center;
        display: flex;
        gap: 10px;
        margin-bottom: 22px;
    }

    .eyebrow span {
        background: var(--blue);
        height: 2px;
        width: 34px;
    }

    .hero h1 {
        color: var(--ink);
        font-size: clamp(2.6rem, 5vw, 4.75rem);
        font-weight: 760;
        letter-spacing: -.045em;
        line-height: .99;
        margin: 0;
        max-width: 820px;
    }

    .hero-lead {
        color: var(--ink-soft);
        font-size: clamp(1rem, 1.4vw, 1.16rem);
        line-height: 1.75;
        margin: 28px 0 0;
        max-width: 700px;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 32px;
    }

    .hero-actions .mud-button-root,
    .closing-actions .mud-button-root {
        border-radius: 6px;
        min-height: 44px;
        padding-inline: 20px;
    }

    .technology-row {
        display: flex;
        flex-wrap: wrap;
        gap: 9px;
        margin-top: 42px;
    }

    .technology-row span {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 999px;
        color: #42526a;
        font-size: .72rem;
        font-weight: 700;
        padding: 7px 11px;
    }

    .hero-diagram {
        align-self: center;
        background: rgba(255, 255, 255, .92);
        border: 1px solid #cbd9ec;
        border-radius: 12px;
        box-shadow: 0 28px 70px rgba(31, 63, 116, .12);
        min-height: 480px;
        padding: 22px;
        position: relative;
    }

    .diagram-heading {
        align-items: center;
        border-bottom: 1px solid var(--line);
        color: #687891;
        display: flex;
        font-size: .7rem;
        font-weight: 800;
        justify-content: space-between;
        letter-spacing: .08em;
        padding-bottom: 16px;
        text-transform: uppercase;
    }

    .diagram-status {
        align-items: center;
        color: var(--teal);
        display: flex;
        gap: 7px;
    }

    .diagram-status i {
        background: #12a594;
        border-radius: 50%;
        box-shadow: 0 0 0 4px rgba(18, 165, 148, .12);
        height: 7px;
        width: 7px;
    }

    .diagram-main {
        display: grid;
        gap: 8px;
        justify-items: center;
        padding: 24px 0 16px;
    }

    .diagram-node {
        align-items: center;
        background: #fff;
        border: 1px solid var(--line);
        border-left: 4px solid var(--blue);
        border-radius: 6px;
        display: flex;
        gap: 13px;
        padding: 13px 15px;
        width: min(100%, 310px);
    }

    .diagram-node .mud-icon-root { color: var(--blue); }
    .diagram-node strong { display: block; font-size: .88rem; }
    .diagram-node span { color: #708098; display: block; font-size: .68rem; margin-top: 2px; }
    .domain-node { border-left-color: var(--teal); }
    .domain-node .mud-icon-root { color: var(--teal); }
    .flow-arrow { color: #91a2ba; font-size: 1rem; line-height: 1; }

    .infra-rail {
        border-top: 1px dashed #b8c6d8;
        padding-top: 16px;
    }

    .infrastructure-node {
        border-left-color: #7c3aed;
        margin: 0 auto;
    }

    .infrastructure-node .mud-icon-root { color: #7c3aed; }

    .adapter-row {
        display: grid;
        gap: 7px;
        grid-template-columns: repeat(4, 1fr);
        margin-top: 12px;
    }

    .adapter-row span {
        background: var(--surface-soft);
        border: 1px solid var(--line);
        border-radius: 4px;
        color: #52627a;
        font-size: .63rem;
        font-weight: 700;
        padding: 7px 4px;
        text-align: center;
    }

    .section {
        padding: clamp(64px, 8vw, 100px) max(28px, calc((100vw - 1240px) / 2));
    }

    .section-intro {
        align-items: end;
        display: grid;
        gap: 40px;
        grid-template-columns: 1.2fr .8fr;
        margin-bottom: 38px;
    }

    .section-intro.compact { grid-template-columns: 1fr; }
    .section-intro h2,
    .growth-copy h2,
    .auth-heading h2,
    .closing-section h2 {
        color: var(--ink);
        font-size: clamp(1.8rem, 3.2vw, 2.7rem);
        letter-spacing: -.035em;
        line-height: 1.08;
        margin: 10px 0 0;
        max-width: 760px;
    }

    .section-intro > p,
    .growth-copy > p {
        color: var(--ink-soft);
        line-height: 1.7;
        margin: 0;
    }

    .capability-section { background: #fff; }

    .capability-grid {
        display: grid;
        gap: 14px;
        grid-template-columns: repeat(3, 1fr);
    }

    .capability-card {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 8px;
        min-height: 240px;
        padding: 22px;
        position: relative;
        transition: border-color .2s ease, transform .2s ease;
    }

    .capability-card:hover { border-color: #9eb8df; transform: translateY(-2px); }
    .capability-card.featured { background: var(--blue-deep); border-color: var(--blue-deep); color: #fff; }
    .capability-card .mud-icon-root { color: var(--blue); font-size: 28px; margin-top: 22px; }
    .capability-card.featured .mud-icon-root { color: #a9c8ff; }
    .card-number { color: #96a4b8; font-size: .65rem; font-weight: 800; letter-spacing: .1em; }
    .capability-card.featured .card-number { color: #8fb4f4; }
    .capability-card h3 { font-size: 1.02rem; margin: 15px 0 7px; }
    .capability-card p { color: var(--ink-soft); font-size: .81rem; line-height: 1.6; margin: 0; }
    .capability-card.featured p { color: #d9e6fb; }
    .card-detail { bottom: 20px; color: var(--blue); font-size: .67rem; font-weight: 800; left: 22px; position: absolute; text-transform: uppercase; }
    .capability-card.featured .card-detail { color: #a9c8ff; }

    .architecture-section { background: var(--surface-soft); border-block: 1px solid var(--line); }
    .layer-list { background: #fff; border: 1px solid var(--line); border-radius: 10px; overflow: hidden; }
    .layer-row {
        align-items: center;
        border-bottom: 1px solid var(--line);
        display: grid;
        gap: 18px;
        grid-template-columns: 34px 44px 1fr auto;
        padding: 20px 24px;
    }
    .layer-row:last-child { border-bottom: 0; }
    .layer-index { color: #9aa8ba; font-size: .65rem; font-weight: 800; }
    .layer-icon { align-items: center; background: var(--blue-soft); border-radius: 7px; color: var(--blue); display: flex; height: 42px; justify-content: center; width: 42px; }
    .layer-copy { min-width: 0; }
    .layer-heading { align-items: baseline; display: flex; flex-wrap: wrap; gap: 10px; }
    .layer-heading h3 { font-size: .92rem; margin: 0; }
    .layer-heading code { color: #6d7c91; font-size: .68rem; }
    .layer-copy p { color: var(--ink-soft); font-size: .76rem; line-height: 1.55; margin: 5px 0 0; }
    .layer-rule { border: 1px solid var(--line); border-radius: 999px; color: #66768e; font-size: .62rem; font-weight: 800; padding: 6px 9px; text-transform: uppercase; }
    .layer-row.domain .layer-icon { background: #e8f7f4; color: var(--teal); }
    .layer-row.infrastructure .layer-icon { background: #f2ecff; color: #7c3aed; }
    .layer-row.migrations .layer-icon { background: #fff5e6; color: #b76b00; }

    .growth-section {
        background: var(--ink);
        color: #fff;
        display: grid;
        gap: clamp(40px, 7vw, 90px);
        grid-template-columns: .85fr 1.15fr;
    }
    .growth-copy h2 { color: #fff; }
    .growth-copy > p { color: #b9c7dc; margin-top: 18px; }
    .growth-section .section-kicker { color: #81adff; }
    .growth-steps { list-style: none; margin: 0; padding: 0; }
    .growth-steps li { align-items: center; border-top: 1px solid rgba(255,255,255,.14); display: grid; gap: 16px; grid-template-columns: 42px 1fr; padding: 17px 0; }
    .growth-steps li:last-child { border-bottom: 1px solid rgba(255,255,255,.14); }
    .growth-steps > li > span { color: #81adff; font-size: .66rem; font-weight: 800; }
    .growth-steps strong { display: block; font-size: .86rem; }
    .growth-steps small { color: #9fb0c7; display: block; font-size: .7rem; margin-top: 3px; }

    .authentication-section { background: #fff; }
    .auth-heading { margin-bottom: 30px; }
    .auth-grid { display: grid; gap: 14px; grid-template-columns: repeat(3, 1fr); }
    .auth-grid article { align-items: flex-start; background: var(--surface-soft); border: 1px solid var(--line); border-radius: 8px; display: flex; gap: 14px; padding: 20px; }
    .auth-grid .mud-icon-root { color: var(--blue); }
    .auth-grid h3 { font-size: .88rem; margin: 0; }
    .auth-grid p { color: var(--ink-soft); font-size: .74rem; line-height: 1.5; margin: 5px 0 0; }

    .closing-section {
        align-items: center;
        background: var(--blue-soft);
        border-top: 1px solid #ccdcf5;
        display: flex;
        gap: 30px;
        justify-content: space-between;
        padding: clamp(50px, 7vw, 78px) max(28px, calc((100vw - 1240px) / 2));
    }
    .closing-section h2 { font-size: clamp(1.55rem, 2.7vw, 2.25rem); max-width: 760px; }
    .closing-actions { display: flex; flex-shrink: 0; gap: 10px; }

    @@media (max-width: 1050px) {
        .hero { grid-template-columns: 1fr; }
        .hero-diagram { width: min(100%, 620px); }
        .capability-grid { grid-template-columns: repeat(2, 1fr); }
        .growth-section { grid-template-columns: 1fr; }
    }

    @@media (max-width: 760px) {
        .architecture-home { margin: -16px; }
        .hero { min-height: auto; padding: 48px 20px; }
        .hero h1 { font-size: clamp(2.35rem, 12vw, 3.5rem); }
        .section { padding: 56px 20px; }
        .section-intro { align-items: start; gap: 18px; grid-template-columns: 1fr; }
        .capability-grid,
        .auth-grid { grid-template-columns: 1fr; }
        .capability-card { min-height: 220px; }
        .adapter-row { grid-template-columns: repeat(2, 1fr); }
        .layer-row { align-items: start; grid-template-columns: 32px 42px 1fr; padding: 18px 14px; }
        .layer-rule { display: none; }
        .layer-heading code { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; width: 100%; }
        .closing-section { align-items: flex-start; flex-direction: column; padding: 48px 20px; }
        .closing-actions { flex-direction: column; width: 100%; }
        .closing-actions .mud-button-root { width: 100%; }
    }

    @@media (max-width: 480px) {
        .hero-actions { flex-direction: column; }
        .hero-actions .mud-button-root { width: 100%; }
        .hero-diagram { padding: 16px; }
        .diagram-heading { align-items: flex-start; flex-direction: column; gap: 8px; }
        .layer-row { grid-template-columns: 26px 1fr; }
        .layer-icon { display: none; }
    }
</style>
